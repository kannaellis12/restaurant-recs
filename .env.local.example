# Copy to .env.local and fill in. .env.local is gitignored.

# --- Reddit API (PRAW) ---
# Create a "script" type app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Per Reddit's API rules, format: "platform:appname:vX.Y (by u/yourusername)"
REDDIT_USER_AGENT=reddit-restaurants:dev:v0.1 (by u/your_username)

# --- Anthropic (pipeline LLMs) ---
ANTHROPIC_API_KEY=

# --- Google Maps Platform ---
# Enable: Places API (New) and Geocoding API in Google Cloud Console.
# Restrict the key to those APIs. Billing must be enabled (free tier covers us).
GOOGLE_MAPS_API_KEY=

# --- Mapbox (frontend map) ---
# Public token. The NEXT_PUBLIC_ prefix exposes it to the browser; that's expected.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Supabase ---
# After creating the project, run: create extension postgis;
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin ---
# Password for /admin route (single-user access for the reconciliation queue).
ADMIN_PASSWORD=
